# Application Settings
PROJECT_NAME="Technotrons Student Portal API"
API_V1_STR="/api"
SECRET_KEY="supersecretkey_change_in_production"
ENVIRONMENT="development"

# Database Configuration (PostgreSQL default, MySQL supported)
# PostgreSQL example: postgresql+asyncpg://user:password@localhost:5432/fiesta
# MySQL example: mysql+aiomysql://root:password@localhost:3306/fiesta
DATABASE_URL="sqlite+aiosqlite:///./fiesta.db"
SQL_ADMIN_PASSWORD="password"

# Firebase Admin SDK Configuration
FIREBASE_CREDENTIALS_PATH=""
FIREBASE_PROJECT_ID="technotrons-campus"

# Google Gemini API
GEMINI_API_KEY="your_gemini_api_key_here"

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "https://*.vercel.app"]
